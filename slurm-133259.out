Kerr(克尔效应)       : ON   n2=7.800e-24 m^2/W | P_cr≈1.214e+10 W  # 自聚焦关键参数
Self-steep.(自陡峭)   : ON   method=tdiff  chunk_px=65536  # 脉冲前沿陡化
